generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  email       String   @unique(map: "users_email") @db.VarChar(255)
  password    String   @db.VarChar(255)
  role        Role?    @default(user)
  lastLoginAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)
  cart        Cart?
  orders      Order[]

  @@map("users")
}

model Product {
  id           String      @id @default(uuid()) @db.Uuid
  name         String      @db.VarChar(255)
  price        Decimal     @db.Decimal(10, 2)
  description  String
  category     Category
  image        String?     @default("https://images.unsplash.com/photo-1560393464-5c69a73c5770?w=600&q=80") @db.VarChar(255)
  countInStock Int         @default(0)
  rating       Decimal?    @default(0) @db.Decimal(3, 2)
  numReviews   Int?        @default(0)
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6)
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@index([category], map: "products_category")
  @@index([name], map: "products_name")
  @@map("products")
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @db.Timestamptz(6)
  userId    String     @unique(map: "carts_user_id") @db.Uuid
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  cartId    String   @db.Uuid
  productId String   @db.Uuid
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId], map: "cart_items_cart_id_product_id")
  @@index([cartId], map: "cart_items_cart_id")
  @@map("cart_items")
}

model Order {
  id                 String       @id @default(uuid()) @db.Uuid
  itemsTotal         Decimal      @db.Decimal(10, 2)
  shippingPrice      Decimal      @default(0) @db.Decimal(10, 2)
  taxPrice           Decimal      @default(0) @db.Decimal(10, 2)
  totalPrice         Decimal      @db.Decimal(10, 2)
  paymentMethod      String       @default("Card") @db.VarChar(255)
  isPaid             Boolean?     @default(false)
  paidAt             DateTime?    @db.Timestamptz(6)
  status             OrderStatus? @default(pending)
  isDelivered        Boolean?     @default(false)
  deliveredAt        DateTime?    @db.Timestamptz(6)
  shippingFullName   String       @db.VarChar(255)
  shippingAddress    String       @db.VarChar(255)
  shippingCity       String       @db.VarChar(255)
  shippingPostalCode String       @db.VarChar(255)
  shippingCountry    String       @db.VarChar(255)
  createdAt          DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @db.Timestamptz(6)
  userId             String       @db.Uuid
  items              OrderItem[]
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status], map: "orders_status")
  @@index([userId], map: "orders_user_id")
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  name      String  @db.VarChar(255)
  image     String  @db.VarChar(255)
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  orderId   String  @db.Uuid
  productId String  @db.Uuid
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId], map: "order_items_order_id")
  @@map("order_items")
}

enum Role {
  user
  admin

  @@map("enum_users_role")
}

enum Category {
  Electronics
  Clothing
  Accessories
  Home
  Furniture
  Fragrance
  Footwear
  Wellness
  Other

  @@map("enum_products_category")
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled

  @@map("enum_orders_status")
}
