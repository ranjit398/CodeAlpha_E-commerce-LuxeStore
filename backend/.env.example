# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── PostgreSQL — Option A: full connection URL ───────────────────────────────
# Use this if your hosting provider gives you a single connection string
# (Railway, Supabase, Render, Heroku, etc.)
DATABASE_URL=postgresql://postgres:890123@localhost:5432/luxestore

# ─── PostgreSQL — Option B: individual fields ─────────────────────────────────
# Sequelize will use these if DATABASE_URL is not set.
# Useful for local development or when you want explicit control.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luxestore
DB_USER=postgres
DB_PASSWORD=890123

# ─── SSL (production only) ────────────────────────────────────────────────────
# Set to true when connecting to managed cloud databases (Supabase, Railway, etc.)
DB_SSL=false
